// pages/api/auth/callback.js
// ─────────────────────────────────────────────────────────────
// Step 2 of GitHub OAuth flow.
// GitHub redirects here with a temporary `code`.
// We exchange that code for a permanent access token,
// then redirect the user back to the homepage with the token
// appended as a URL hash fragment (never touches the server log).
// ─────────────────────────────────────────────────────────────

export default async function handler(req, res) {
  const { code } = req.query

  if (!code) {
    return res.status(400).send('Missing OAuth code from GitHub.')
  }

  const clientId     = process.env.GITHUB_CLIENT_ID
  const clientSecret = process.env.GITHUB_CLIENT_SECRET

  if (!clientId || !clientSecret) {
    return res.status(500).send(
      'Server misconfiguration: GitHub credentials not set in .env.local'
    )
  }

  try {
    // Exchange the temporary code for a real access token
    const tokenResponse = await fetch(
      'https://github.com/login/oauth/access_token',
      {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json', // Ask GitHub to return JSON (not form-encoded)
        },
        body: JSON.stringify({
          client_id:     clientId,
          client_secret: clientSecret,
          code,
        }),
      }
    )

    const tokenData = await tokenResponse.json()

    if (tokenData.error || !tokenData.access_token) {
      console.error('GitHub token error:', tokenData)
      return res.status(400).send(
        `GitHub OAuth error: ${tokenData.error_description || 'Unknown error'}`
      )
    }

    // ⚠️ Security note:
    // We pass the token via the URL hash (#token=...) so it is NEVER sent to
    // the server by the browser (hash fragments stay client-side only).
    // For production, prefer HttpOnly cookies + a server-side session store.
    const appUrl = process.env.NEXT_PUBLIC_APP_URL || 'http://localhost:3000'
    res.redirect(`${appUrl}/#token=${tokenData.access_token}`)

  } catch (err) {
    console.error('OAuth callback error:', err)
    res.status(500).send('Internal server error during GitHub OAuth.')
  }
}
